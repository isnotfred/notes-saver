<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="fred.was.here.notessaver.controller.LoginController"
      styleClass="auth-root"
      alignment="CENTER" spacing="0"
      prefWidth="420" prefHeight="520">

    <!-- Card -->
    <VBox styleClass="auth-card" spacing="20" maxWidth="360"
          VBox.vgrow="NEVER" alignment="CENTER">

        <Label text="📓" styleClass="app-icon"/>
        <Label text="NotesVault" styleClass="app-title"/>
        <Label text="Sign in to your account" styleClass="auth-subtitle"/>

        <VBox spacing="12">
            <Label text="Username" styleClass="field-label"/>
            <TextField fx:id="usernameField" promptText="Enter username" styleClass="text-input"/>

            <Label text="Password" styleClass="field-label"/>
            <PasswordField fx:id="passwordField" promptText="Enter password" styleClass="text-input"/>

            <Label fx:id="errorLabel" styleClass="error-label" wrapText="true"/>
        </VBox>

        <Button fx:id="loginBtn" text="Login" onAction="#handleLogin"
                styleClass="btn-primary" maxWidth="Infinity"/>

        <Separator/>

        <HBox alignment="CENTER" spacing="6">
            <Label text="Don't have an account?" styleClass="auth-link-text"/>
            <Button text="Register here" onAction="#goToRegister" styleClass="btn-link"/>
        </HBox>
    </VBox>
</VBox>
