<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="fred.was.here.notessaver.controller.RegisterController"
      styleClass="auth-root"
      alignment="CENTER" spacing="0"
      prefWidth="420" prefHeight="580">

    <VBox styleClass="auth-card" spacing="16" maxWidth="360"
          VBox.vgrow="NEVER" alignment="CENTER">

        <Label text="📓" styleClass="app-icon"/>
        <Label text="Create Account" styleClass="app-title"/>
        <Label text="Join NotesVault today" styleClass="auth-subtitle"/>

        <VBox spacing="10">
            <Label text="Username" styleClass="field-label"/>
            <TextField fx:id="usernameField" promptText="At least 3 characters" styleClass="text-input"/>

            <Label text="Email" styleClass="field-label"/>
            <TextField fx:id="emailField" promptText="you@example.com" styleClass="text-input"/>

            <Label text="Password" styleClass="field-label"/>
            <PasswordField fx:id="passwordField" promptText="At least 6 characters" styleClass="text-input"/>

            <Label text="Confirm Password" styleClass="field-label"/>
            <PasswordField fx:id="confirmPasswordField" promptText="Repeat your password" styleClass="text-input"/>

            <Label fx:id="errorLabel" styleClass="error-label" wrapText="true"/>
        </VBox>

        <Button fx:id="registerBtn" text="Create Account" onAction="#handleRegister"
                styleClass="btn-primary" maxWidth="Infinity"/>

        <Separator/>

        <HBox alignment="CENTER" spacing="6">
            <Label text="Already have an account?" styleClass="auth-link-text"/>
            <Button text="Login" onAction="#goToLogin" styleClass="btn-link"/>
        </HBox>
    </VBox>
</VBox>
