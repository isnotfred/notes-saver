<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="fred.was.here.notessaver.controller.DashboardController"
            styleClass="dashboard-root"
            prefWidth="800" prefHeight="600">

    <!-- TOP BAR -->
    <top>
        <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="12">
            <Label text="📓" styleClass="topbar-icon"/>
            <Label text="NotesVault" styleClass="topbar-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="greetingLabel" styleClass="greeting-label"/>
            <Button fx:id="logoutBtn" text="Logout" onAction="#handleLogout" styleClass="btn-secondary"/>
        </HBox>
    </top>

    <!-- SIDEBAR: search + new note -->
    <left>
        <VBox styleClass="sidebar" spacing="12" prefWidth="220">
            <padding><Insets top="16" right="12" bottom="16" left="12"/></padding>
            <Button text="＋  New Note" onAction="#handleNewNote"
                    styleClass="btn-primary" maxWidth="Infinity"/>
            <TextField fx:id="searchField" promptText="🔍  Search notes…" styleClass="text-input"/>
            <Label fx:id="statusLabel" styleClass="status-label"/>
        </VBox>
    </left>

    <!-- NOTE LIST -->
    <center>
        <VBox styleClass="notes-panel">
            <ListView fx:id="noteListView" styleClass="note-list" VBox.vgrow="ALWAYS"/>
        </VBox>
    </center>
</BorderPane>
